# PostgreSQL Database Configuration Template
# 
# Copy to postgres.env and configure database connection settings
# cp postgres.env.example postgres.env
#
# Variables used by: docker-compose.yml (db and api services)

POSTGRES_DB=nurax_db
POSTGRES_USER=nurax_user
POSTGRES_PASSWORD=nurax_password
DB_HOST=db                # 'db' for Docker, 'localhost' for local
DB_NAME=nurax_db
DB_USER=nurax_user
DB_PASSWORD=nurax_password
DB_SSLMODE=disable        # 'disable' in dev, 'require' in prod
DB_PORT=5432
